{
  "name": "souqna",
  "version": "0.1.0",
  "private": true,
  "description": "Souqna - bilingual commerce workspace for Gulf storefronts.",
  "scripts": {
    "dev": "next dev",
    "migrate": "node scripts/migrate.mjs",
    "build": "node scripts/production-guard.mjs build && node scripts/migrate.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "guard:commit": "node scripts/production-guard.mjs commit",
    "guard:deploy": "node scripts/production-guard.mjs deploy",
    "guard:prod": "node scripts/production-guard.mjs deploy --prod",
    "deploy:preview": "npm run guard:deploy && vercel deploy",
    "deploy:prod": "npm run guard:prod && vercel deploy --prod",
    "pulse:install": "cd apps/pulse && npm install",
    "pulse:icons": "bash apps/pulse/scripts/make-icons.sh",
    "pulse:dev": "cd apps/pulse && npm run tauri:dev",
    "pulse:build": "cd apps/pulse && npm run tauri:build",
    "mobile:install": "cd apps/mobile && npm install",
    "mobile:dev": "cd apps/mobile && npm run dev",
    "mobile:ios": "cd apps/mobile && npm run ios",
    "mobile:typecheck": "cd apps/mobile && npm run typecheck"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "@clerk/nextjs": "6.39.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "^1.1.0",
    "@react-three/drei": "9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/sandbox": "^1.10.0",
    "ai": "^6.0.168",
    "apify-client": "^2.23.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "11.18.2",
    "gsap": "^3.15.0",
    "lru-cache": "11.0.2",
    "lucide-react": "^1.14.0",
    "metal-fx": "^1.0.3",
    "motion": "^12.38.0",
    "next": "14.2.35",
    "next-intl": "3.26.5",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "openai": "^6.37.0",
    "posthog-js": "^1.372.5",
    "posthog-node": "^5.31.0",
    "postmark": "^4.0.7",
    "pusher": "^5.3.3",
    "radix-ui": "^1.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "4.1.2",
    "simple-icons": "^16.18.1",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.0.7",
    "@types/node": "^22.13.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/three": "^0.184.1",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.5.3",
    "prettier": "3.5.2",
    "tailwindcss": "4.0.7",
    "tsup": "^8.5.1",
    "typescript": "5.7.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
